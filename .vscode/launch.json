{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI (Local)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.api:app", "--host", "0.0.0.0", "--port", "8080", "--reload"],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "ENV": "local"
      },
      "console": "integratedTerminal",
      "justMyCode": false,
      "python": "${workspaceFolder}/backend/.venv/bin/python"
    },
    {
      "name": "Backend: FastAPI (Debug Mode)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.api:app", "--host", "0.0.0.0", "--port", "8080", "--reload"],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "ENV": "debug"
      },
      "console": "integratedTerminal",
      "justMyCode": false,
      "python": "${workspaceFolder}/backend/.venv/bin/python"
    },
    {
      "name": "Backend: Attach to Running Process",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      }
    },
    {
      "name": "Backend: Run main.py (Local)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/main.py",
      "args": ["--env", "local"],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "justMyCode": false,
      "python": "${workspaceFolder}/backend/.venv/bin/python"
    },
    {
      "name": "Frontend SvelteKit: Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend-svelt",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:.*(https?://[^ ]+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Frontend SvelteKit: Debug in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend-svelt",
      "sourceMaps": true
    }
  ]
}
