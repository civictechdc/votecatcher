# OCR Provider Configuration (Required unless using simulation mode)
OCR_PROVIDER_NAME=open_ai
OCR_PROVIDER_MODEL=gpt-4o-mini
OCR_PROVIDER_API_KEY=your-api-key-here

# Database (Required)
# SQLite for development:
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/votecatcher

# Development Settings (Optional)
DEV_LOGGING_ENABLED=1
DEV_LOCAL_DB_ENABLE_LOGGING=0

# Feature Flags (Optional)
# Set FEATURE_ENABLE_SIMULATION=1 to mock OCR without API key
FEATURE_ENABLE_SIMULATION=0
FEATURE_ENABLE_BETA_FEATURES=0
FEATURE_ENABLE_DEBUG_MODE=0
FEATURE_DEMO_MODE=0
FEATURE_DEMO_RESET=0

# See docs/configuration-modes.md for all configuration options
