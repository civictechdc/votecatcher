# Backend API URL (Required - do NOT include /api suffix)
PUBLIC_API_URL=http://localhost:8000

# Demo mode - uses sample data (Optional)
DEMO_MODE=1
# App origin for CORS (Optional)
ORIGIN=http://localhost:5173
# Better Auth secret (Required for sessions)
BETTER_AUTH_SECRET=generate-a-secure-secret-here

# Database connection for server-side operations (Optional)
# Only needed if using server-side database access
# DATABASE_URL=postgresql://user:password@host:port/db-name
