[
  {
    "label": "Backend: FastAPI (Local)",
    "adapter": "Debugpy",
    "request": "launch",
    "module": "uvicorn",
    "args": ["app.api:app", "--host", "0.0.0.0", "--port", "8080", "--reload"],
    "cwd": "$ZED_WORKTREE_ROOT/backend",
    "env": {
      "ENV": "local"
    }
  },
  {
    "label": "Backend: Run main.py",
    "adapter": "Debugpy",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/backend/main.py",
    "args": ["--env", "local"],
    "cwd": "$ZED_WORKTREE_ROOT/backend"
  },
  {
    "label": "Backend: Attach to Process",
    "adapter": "Debugpy",
    "request": "attach",
    "connect": {
      "host": "localhost",
      "port": 5678
    }
  },
  {
    "label": "Frontend: Node Debug",
    "adapter": "JavaScript",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/frontend/node_modules/vite/bin/vite.js",
    "args": ["--host"],
    "cwd": "$ZED_WORKTREE_ROOT/frontend"
  }
]
