# Backend API URL (Required - do NOT include /api suffix)
PUBLIC_API_URL=http://localhost:8080

# Demo mode - enables /workspace/demo route with sample data
# Set both to "true" for demo mode
PUBLIC_DEMO_MODE=false
DEMO_MODE=false

# App origin for CORS (Optional)
ORIGIN=http://localhost:5173

# === Database ===
# PostgreSQL connection for SvelteKit server (required for auth)
DATABASE_URL=postgresql://user:pass@localhost:5432/votecatcher  # pragma: allowlist secret

# === Auth ===
# Better Auth secret (Required for sessions)
BETTER_AUTH_SECRET=generate-a-secure-secret-here

# === OCR Provider ===
# Required unless using simulation mode
OCR_PROVIDER_NAME=openai
OCR_PROVIDER_MODEL=gpt-4o-mini
OCR_PROVIDER_API_KEY=your-api-key-here

# See docs/configuration-modes.md for all configuration options
