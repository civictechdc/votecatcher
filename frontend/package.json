{
	"name": "frontend",
	"version": "1.0.0-a9",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:e2e": "playwright test",
		"test": "vitest run && playwright test",
		"test:unit": "vitest",
		"format": "oxfmt",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "bunx @better-auth/cli generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"fmt": "oxfmt --ignore-path .oxfmtignore",
		"fmt:check": "oxfmt --check --ignore-path .oxfmtignore"
	},
	"dependencies": {
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"clsx": "^2.1.1",
		"cookie": "^1.1.1",
		"esbuild": "^0.28.0",
		"lucide-svelte": "^1.0.1",
		"path-to-regexp": "^8.4.2",
		"postcss": "^8.5.15",
		"postgres": "^3.4.9",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.4.0",
		"@openapitools/openapi-generator-cli": "^2.34.0",
		"@playwright/test": "^1.60.0",
		"@storybook/addon-a11y": "^10.4.1",
		"@storybook/addon-docs": "^10.4.1",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.1",
		"@storybook/sveltekit": "^10.4.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/svelte": "^5.3.1",
		"@types/jsdom": "^28.0.3",
		"@types/node": "^25.9.1",
		"@vitest/browser": "^4.1.7",
		"@vitest/browser-playwright": "^4.1.7",
		"@vitest/coverage-v8": "^4.1.7",
		"better-auth": "^1.6.11",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.4.0",
		"eslint-plugin-storybook": "^10.4.1",
		"eslint-plugin-svelte": "^3.17.1",
		"fallow": "^2.80.0",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"msw": "^2.14.6",
		"oxfmt": "^0.51.0",
		"oxlint": "^1.66.0",
		"playwright": "^1.60.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"storybook": "^10.4.1",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4",
		"vite": "^8.0.14",
		"vite-plugin-oxlint": "^2.1.1",
		"vitest": "^4.1.7"
	},
	"overrides": {
		"basic-ftp": ">=5.3.1",
		"brace-expansion": ">=5.0.6",
		"cookie": ">=0.7.0",
		"cross-spawn": ">=7.0.5",
		"esbuild": ">=0.25.0",
		"follow-redirects": ">=1.16.0",
		"glob": ">=10.5.0",
		"ip-address": ">=10.1.1",
		"minimatch": ">=10.2.3",
		"path-to-regexp": ">=8.4.0",
		"picomatch": ">=4.0.4",
		"postcss": ">=8.5.10",
		"tar": ">=7.5.11",
		"ws": ">=8.20.1"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint",
		"*": "oxfmt --no-error-on-unmatched-pattern"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "bun@1.3.9",
	"trustedDependencies": []
}
