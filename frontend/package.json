{
	"name": "frontend",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:e2e": "playwright test",
		"test": "vitest run && playwright test",
		"test:unit": "vitest",
		"format": "oxfmt",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "bunx @better-auth/cli generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"fmt": "oxfmt --ignore-path .oxfmtignore",
		"fmt:check": "oxfmt --check --ignore-path .oxfmtignore"
	},
	"dependencies": {
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"clsx": "^2.1.1",
		"lucide-svelte": "^0.576.0",
		"postgres": "^3.4.9",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@chromatic-com/storybook": "^5.1.1",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^9.39.4",
		"@faker-js/faker": "^10.4.0",
		"@openapitools/openapi-generator-cli": "^2.31.0",
		"@playwright/test": "^1.59.1",
		"@storybook/addon-a11y": "^10.3.4",
		"@storybook/addon-docs": "^10.3.4",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.4",
		"@storybook/sveltekit": "^10.3.4",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/svelte": "^5.3.1",
		"@types/jsdom": "^28.0.1",
		"@types/node": "^24.12.2",
		"@vitest/browser": "^4.1.2",
		"@vitest/browser-playwright": "^4.1.2",
		"@vitest/coverage-v8": "^4.1.2",
		"better-auth": "^1.5.6",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^9.39.4",
		"eslint-plugin-storybook": "^10.3.4",
		"eslint-plugin-svelte": "^3.17.0",
		"fallow": "^2.13.3",
		"globals": "^17.4.0",
		"jsdom": "^28.1.0",
		"msw": "^2.12.14",
		"oxfmt": "^0.33.0",
		"oxlint": "^1.58.0",
		"playwright": "^1.59.1",
		"rollup-plugin-visualizer": "^7.0.1",
		"storybook": "^10.3.4",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"vite": "^7.3.1",
		"vite-plugin-oxlint": "^1.7.0",
		"vitest": "^4.1.2"
	},
	"overrides": {
		"minimatch": ">=10.2.3",
		"picomatch": ">=4.0.4",
		"tar": ">=7.5.11"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint",
		"*": "oxfmt --no-error-on-unmatched-pattern"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "bun@1.3.9",
	"trustedDependencies": []
}
